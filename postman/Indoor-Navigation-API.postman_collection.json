    {
      "name": "Floors",
      "item": [
        {
          "name": "Create Floor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "  pm.environment.set('floorId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"building_id\": \"{{buildingId}}\",\n  \"level_number\": 1,\n  \"name\": \"Floor 1\",\n  \"height_meters\": 3.0,\n  \"floor_geojson\": {\n    \"type\": \"FeatureCollection\",\n    \"features\": []\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/floors",
