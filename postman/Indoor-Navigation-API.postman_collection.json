    {
      "name": "Buildings",
      "item": [
        {
          "name": "Create Building",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body && body.id) {",
                  "  pm.environment.set('buildingId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Building\",\n  \"description\": \"Campus building\",\n  \"floors_count\": 0,\n  \"geometry_wkt\": \"POLYGON((31.2 30.0, 31.21 30.0, 31.21 30.01, 31.2 30.01, 31.2 30.0))\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/buildings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "buildings"
              ]
            }
          }
        },
        {
          "name": "Get Building",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
