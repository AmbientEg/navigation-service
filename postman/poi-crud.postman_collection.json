{
    "info": {
        "name": "POI CRUD — navigation-service",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "Update and Delete endpoints added to the navigation service for POI management."
    },
    "item": [
        {
            "name": "PUT /api/admin/pois/:poi_id",
            "request": {
                "method": "PUT",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}",
                        "type": "text"
                    },
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"lab-33-updated\",\n  \"type\": \"lab\",\n  \"geometry_wkt\": \"POINT(31.2015 30.0277)\",\n  \"metadata\": {\n    \"label\": \"Lab 33 Updated\",\n    \"space_type\": \"lab\",\n    \"walkable\": true,\n    \"selectable\": true,\n    \"editable\": true\n  }\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/admin/pois/{{poiId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "admin",
                        "pois",
                        "{{poiId}}"
                    ]
                },
                "description": "Update an existing POI. All fields are optional — only provided fields are updated.\n\nFields:\n- name: slug-style name (e.g. lab-33)\n- type: lecture_hall | lab | office | toilet | elevator | stairs\n- geometry_wkt: WKT point string e.g. POINT(lng lat)\n- metadata: arbitrary JSON stored in extra_data"
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                            "const data = pm.response.json();",
                            "pm.test('returns updated poi id', function () { pm.expect(data.id).to.not.be.empty; });"
                        ]
                    }
                }
            ]
        },
        {
            "name": "DELETE /api/admin/pois/:poi_id",
            "request": {
                "method": "DELETE",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/admin/pois/{{poiId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "admin",
                        "pois",
                        "{{poiId}}"
                    ]
                },
                "description": "Permanently delete a POI by its UUID. Returns { success: true, id: \"...\" } on success."
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                            "const data = pm.response.json();",
                            "pm.test('success is true', function () { pm.expect(data.success).to.be.true; });",
                            "pm.test('id returned', function () { pm.expect(data.id).to.not.be.empty; });"
                        ]
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8001",
            "description": "Navigation service base URL"
        },
        {
            "key": "adminToken",
            "value": "test-admin-token",
            "description": "Admin API token from ADMIN_API_TOKEN env var"
        },
        {
            "key": "poiId",
            "value": "",
            "description": "UUID of the POI to update/delete — set this before running"
        }
    ]
}