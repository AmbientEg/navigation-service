{
  "info": {
    "name": "navigation-service-local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Local Postman collection for floor3 graph persistence + navigation route testing"
  },
  "item": [
    {
      "name": "01 Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /api/status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/status"
          }
        }
      ]
    },
    {
      "name": "02 Persist floor3 graph",
      "item": [
        {
          "name": "POST /api/admin/graph/persist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"graph_geojson_path\": \"{{graphGeojsonPath}}\",\n  \"floor_geojson_path\": \"{{floorGeojsonPath}}\",\n  \"building_name\": \"{{buildingName}}\",\n  \"building_description\": \"Postman floor3 test\",\n  \"floor_level\": 3,\n  \"floor_name\": \"3rd Floor\",\n  \"floor_height\": 3.0,\n  \"clear_existing_floor_data\": true\n}"
            },
            "url": "{{baseUrl}}/api/admin/graph/persist"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (data.floor_id) { pm.environment.set('floorId', data.floor_id); }",
                  "pm.test('persist status ok', function () { pm.expect(data.status).to.eql('ok'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 Discover IDs",
      "item": [
        {
          "name": "GET /api/admin/floors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/admin/floors"
          }
        },
        {
          "name": "GET /api/admin/pois (capture first POI on floorId)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/admin/pois"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const arr = pm.response.json();",
                  "const floorId = pm.environment.get('floorId');",
                  "if (Array.isArray(arr) && floorId) {",
                  "  const match = arr.find(p => p.floor_id === floorId);",
                  "  if (match && match.id) { pm.environment.set('poiId', match.id); }",
                  "}",
                  "pm.test('poiId captured', function () { pm.expect(pm.environment.get('poiId')).to.not.be.empty; });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 Route tests",
      "item": [
        {
          "name": "POST /api/navigation/route (accessible=true)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": {\n    \"floorId\": \"{{floorId}}\",\n    \"lat\": {{startLat}},\n    \"lng\": {{startLng}}\n  },\n  \"to\": {\n    \"poiId\": \"{{poiId}}\"\n  },\n  \"options\": {\n    \"accessible\": true\n  }\n}"
            },
            "url": "{{baseUrl}}/api/navigation/route"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "pm.test('distance positive', function () { pm.expect(data.distance).to.be.above(0); });",
                  "pm.test('has steps', function () { pm.expect(data.steps.length).to.be.above(0); });",
                  "pm.test('has floor path', function () { pm.expect(data.floors.length).to.be.above(0); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/navigation/route (invalid lat edge-case)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": {\n    \"floorId\": \"{{floorId}}\",\n    \"lat\": 999,\n    \"lng\": {{startLng}}\n  },\n  \"to\": {\n    \"poiId\": \"{{poiId}}\"\n  },\n  \"options\": {\n    \"accessible\": true\n  }\n}"
            },
            "url": "{{baseUrl}}/api/navigation/route"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 404 for invalid coordinates', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}