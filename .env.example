# =============================================================================
# Navigation Service Environment Configuration
# Copy this file to .env and customize for your environment
# =============================================================================

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_PORT=8000

# =============================================================================
# Database Configuration (Neon Serverless PostgreSQL)
# =============================================================================
# Get your connection string from: https://neon.tech
# Format: postgresql+asyncpg://user:password@host.neon.tech/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@your-project.neon.tech/navigation?ssl=require

# Test Database (separate Neon database or Neon branch recommended)
TEST_DATABASE_URL=postgresql+asyncpg://user:password@your-project.neon.tech/navigation_test?ssl=require

# =============================================================================
# CORS and Security
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1,api.example.com

# =============================================================================
# Nginx / Load Balancer
# =============================================================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# =============================================================================
# User Configuration (for container security)
# =============================================================================
APP_UID=1000
APP_GID=1000

# =============================================================================
# AWS Lambda Settings (if deploying to Lambda)
# =============================================================================
AWS_LAMBDA_FUNCTION_NAME=
AWS_REGION=us-east-1
